APP_NAME="f29.us Dynamic QR"
# Environment: local | staging | production
APP_ENV=local
APP_URL=http://localhost:8000
APP_DEBUG=false

# Secret key for HMAC hashing of IPs in login throttle.
# Generate with: php -r "echo bin2hex(random_bytes(32));"
APP_KEY=

# Base URL encoded into QR images. Use the production domain so downloaded
# QR files work in the real world, not the dev server address.
QR_BASE_URL=https://f29.us

DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=f29us_qr
DB_USERNAME=root
DB_PASSWORD=

# Contact email addresses shown on public policy pages.
# Optional — defaults are used if not set.
SUPPORT_EMAIL=support@f29.us
ABUSE_EMAIL=abuse@f29.us
PRIVACY_EMAIL=privacy@f29.us

# Transactional email via SMTP (PHPMailer).
# Set MAIL_ENABLED=true and configure SMTP credentials to enable sending.
# When false, notification calls are silent no-ops — no errors are raised.
MAIL_ENABLED=false
MAIL_FROM_ADDRESS=no-reply@f29.us
MAIL_FROM_NAME="f29.us"
MAIL_SMTP_HOST=smtp.example.com
MAIL_SMTP_PORT=587
MAIL_SMTP_ENCRYPTION=tls
MAIL_SMTP_USERNAME=
MAIL_SMTP_PASSWORD=
# Support address included in security-alert emails (denied/canceled plan requests,
# email-change and password-change notices). Falls back to SUPPORT_EMAIL if not set.
MAIL_SUPPORT_ADDRESS=support@f29.us
# Optional: address to notify when a user submits a new plan-change request.
# Leave blank to disable admin notification emails.
MAIL_ADMIN_ADDRESS=

# ── Stripe ────────────────────────────────────────────────────────────────────
# Set STRIPE_ENABLED=true and configure credentials to activate billing.
# STRIPE_MODE: test | live
# STRIPE_SECRET_KEY and STRIPE_WEBHOOK_SECRET must never appear in logs or browser output.
# STRIPE_PUBLISHABLE_KEY is safe to display (it is a public key).
STRIPE_ENABLED=false
STRIPE_MODE=test
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=https://f29.us/account/subscription?checkout=success
STRIPE_CANCEL_URL=https://f29.us/account/subscription?checkout=canceled
STRIPE_CURRENCY=usd
